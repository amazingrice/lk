import javax.swing.*;
import java.awt.*;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;
public class GUI {
    public static void main(String[] args) {
        JFrame frame = new JFrame("Scanner and Parser");
        frame.setSize(1000, 600); 
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setLayout(new BorderLayout(15, 15)); 
      
        frame.getContentPane().setBackground(Color.pink);
        ((JPanel)frame.getContentPane()).setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));

        JPanel centerPanel = new JPanel(new GridLayout(1, 2, 15, 0));
        centerPanel.setBackground(Color.pink);

        JPanel quellPanel = new JPanel(new BorderLayout(0, 5));
        quellPanel.setBackground(Color.pink);
        JLabel quellLabel = new JLabel("Quelltext:");
        JTextArea quellArea = new JTextArea();
        quellPanel.add(quellLabel, BorderLayout.NORTH);
        quellPanel.add(new JScrollPane(quellArea), BorderLayout.CENTER);

        centerPanel.add(quellPanel);
        frame.add(centerPanel, BorderLayout.CENTER);
        frame.setVisible(true);
    }
}
